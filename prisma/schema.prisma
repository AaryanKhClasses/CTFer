generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model CTF {
    id          String      @id @default(uuid())
    name        String
    users       User[]

    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
}

model User {
    id          String      @id @default(uuid())
    name        String
    email       String
    password    String
    ctfId       String
    type        String      @default("participant")

    ctf         CTF         @relation(fields: [ctfId], references: [id])
    
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
}